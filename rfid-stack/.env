# ╔══════════════════════════════════════════════════════════════╗
# ║   Arturo Calle RFID — Variables de entorno del stack         ║
# ║   Copia este archivo como .env y ajusta los valores          ║
# ╚══════════════════════════════════════════════════════════════╝

# ── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=production

# ── MySQL ────────────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=root_password_change_me
MYSQL_DATABASE=rfid_db
MYSQL_USER=rfid_user
MYSQL_PASSWORD=rfid_password
MYSQL_HOST_PORT=3306           # puerto expuesto en el host

# ── JWT — CAMBIAR EN PRODUCCIÓN ──────────────────────────────────────────────
JWT_SECRET=change_me_in_production_at_least_32_characters_long
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_refresh_in_production_min_32_chars_long
JWT_REFRESH_EXPIRES_IN=7d

# ── Puertos expuestos en el host ─────────────────────────────────────────────
API_HOST_PORT=3000             # REST API + WebSocket
FRONTEND_HOST_PORT=80          # Frontend (nginx)
ADMINER_HOST_PORT=8080         # Solo con --profile tools

# ── Rate limit ───────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200

# ── RFID ─────────────────────────────────────────────────────────────────────
# false = simulador integrado  |  true = lectoras físicas LLRP
RFID_REAL_READERS=false
RFID_RECONNECT_INTERVAL=5000
RFID_HEARTBEAT_TIMEOUT=30000

# ── Alertas y reportes ───────────────────────────────────────────────────────
LOW_STOCK_THRESHOLD=10
ALERT_CHECK_CRON=*/5 * * * *
