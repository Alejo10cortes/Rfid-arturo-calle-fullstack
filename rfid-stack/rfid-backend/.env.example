# ── APP ────────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1

# ── DATABASE ───────────────────────────────────────────────────────────────────
DATABASE_URL="mysql://rfid_user:rfid_password@localhost:3306/rfid_db"

# ── JWT ────────────────────────────────────────────────────────────────────────
JWT_SECRET=super_secret_jwt_key_change_in_production_min_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=super_secret_refresh_key_change_in_production_min_32_chars
JWT_REFRESH_EXPIRES_IN=7d

# ── CORS ───────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3001

# ── RATE LIMIT ─────────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200

# ── RFID / LLRP ────────────────────────────────────────────────────────────────
# Habilita el driver real de lectoras (false = usa simulador)
RFID_REAL_READERS=false
# Tiempo máximo de reconexión a lectoras (ms)
RFID_RECONNECT_INTERVAL=5000
# Tiempo sin actividad para marcar lector offline (ms)
RFID_HEARTBEAT_TIMEOUT=30000

# ── ALERTS ─────────────────────────────────────────────────────────────────────
LOW_STOCK_THRESHOLD=10
# Cron para chequeo automático de alertas
ALERT_CHECK_CRON=*/5 * * * *

# ── REPORTS ────────────────────────────────────────────────────────────────────
REPORTS_OUTPUT_DIR=./reports
